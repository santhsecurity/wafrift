# Allow-list: governance artifacts AND shipped code that the broad
# planning-doc patterns above would otherwise sweep up. Order matters:
# later `!` re-includes win over earlier `*` excludes.
!CODE_OF_CONDUCT.md
!SECURITY.md
# The `wafrift legendary` one-shot command — real Rust source, not a
# "LEGENDARY_PLAN.md" planning doc.
!crates/cli/src/legendary.rs
# Public bypass-rate scoreboard, refreshed by CI from wafrift-bench
# results — the `SCOREBOARD*.md` pattern above blocks stray local
# scoreboards but this one is the canonical published artefact.
!docs/SCOREBOARD.md
!CONTRIBUTING.md
!LICENSE
!LICENSE-APACHE
!LICENSE-MIT
# ── Santh-internal artifacts (END) ──

# Per-session dogfood scratch + Python __pycache__ — never commit.
.tmp_*
__pycache__/
*.pyc

# Per-run dogfood-sweep transcripts (bash + PowerShell) write to
# wafrift-bench/results/dogfood-*. Operator-private, never committed —
# each run produces fresh logs.
wafrift-bench/results/dogfood-*
# Per-run smoke / zoo / live bench artifacts — same rationale.
# Match both "zoo-*" prefix and "<timestamp>-zoo-*" / "<timestamp>-cf-*"
# / "<timestamp>-live-*" generated by the dated-bench runner.
wafrift-bench/results/zoo-*
wafrift-bench/results/cf-*
wafrift-bench/results/live-*
wafrift-bench/results/*-zoo-*
wafrift-bench/results/*-cf-*
wafrift-bench/results/*-live-*

# Local-only scaffolded `wafrift scan` config — every operator has
# their own values. The committed reference lives in `docs/`.
.wafrift.toml
