#[test]
fn dump_for_corpus() {
    let payloads = ["1' OR '1'='1", "' AND 1=1--", "1' UNION SELECT 1--", "admin'--", "'+OR+1=1--", "1%27%20OR%20%271%27%3D%271"];
    for p in payloads {
        eprintln!("\n--- input: {p} ---");
        let muts = wafrift_grammar::grammar::sql::quote_free::mutations(p, 10);
        for m in &muts {
            eprintln!("  → {} | {}", m.payload, m.description);
        }
        if muts.is_empty() {
            eprintln!("  (no mutations)");
        }
    }
}
